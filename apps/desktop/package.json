{
  "name": "desktop",
  "version": "0.1.0",
  "description": "Awards Centre Point of Sale System",
  "author": "Awards Centre",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:start": "electron .",
    "prebuild": "npx shx mkdir -p server_dist && npx shx cp -r ../server/src server_dist/ && npx shx cp ../server/prisma/dev.db server_dist/ && npx shx cp -r ../server/node_modules server_dist/",
    "dist": "npm run prebuild && npm run build && electron-builder"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.awardscentre.pos",
    "productName": "Awards Centre POS",
    "electronVersion": "30.0.0",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json",
      "server_dist/**/*"
    ],
    "asarUnpack": [
      "server_dist/**/*"
    ],
    "win": {
      "target": "portable"
    }
  },
  "dependencies": {
    "cross-env": "^10.1.0",
    "electron-serve": "^3.0.1",
    "framer-motion": "^11.2.6",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "electron": "30.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.4.5",
    "wait-on": "^7.2.0"
  }
}
