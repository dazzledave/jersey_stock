generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMethod {
  cash
  momo
  card
  credit
  free
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt

  @@map("categories")
}

model Product {
  id         String           @id @default(cuid())
  name       String
  brand      String?
  basePrice  Float            @map("base_price")
  costPrice  Float            @default(0) @map("cost_price")
  categoryId String           @map("category_id")
  imageUrl   String?          @map("image_url")
  category   Category         @relation(fields: [categoryId], references: [id])
  variants   ProductVariant[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @default(now()) @updatedAt

  @@map("products")
}

model ProductVariant {
  id        String          @id @default(cuid())
  productId String          @map("product_id")
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      String?
  color     String?
  sku       String?         @unique
  barcode   String?         @unique
  inventory Inventory?
  movements StockMovement[]
  saleItems SaleItem[]
  updatedAt DateTime        @default(now()) @updatedAt

  @@map("product_variants")
}

model Inventory {
  variantId    String         @id @map("variant_id")
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity     Int            @default(0)
  reorderLevel Int            @default(5) @map("reorder_level")
  updatedAt    DateTime       @default(now()) @updatedAt

  @@map("inventory")
}

model StockMovement {
  id        String         @id @default(cuid())
  variantId String         @map("variant_id")
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int // positive for additions, negative for reductions
  type      String // e.g., "SALE", "ADJUSTMENT", "RESTOCK"
  reason    String?
  createdAt DateTime       @default(now())

  @@map("StockMovement")
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?  @unique
  email     String?  @unique
  address   String?
  sales     Sale[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("customers")
}

model User {
  id              String   @id @default(cuid())
  username        String   @unique
  password        String
  visiblePassword String?  @map("visible_password")
  role            String   @default("STAFF") // "ADMIN" or "STAFF"
  sales           Sale[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@map("users")
}

model SyncLog {
  id        String   @id @default(cuid())
  entity    String?  // "Sale", "Product", etc.
  entityId  String?  @map("entity_id")
  status    String   @default("PENDING") // "PENDING", "SYNCED", "FAILED"
  message   String?  // For manual sync logs
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("sync_logs")
}

model Setting {
  key   String @id
  value String

  @@map("settings")
}

model Sale {
  id            String        @id @default(cuid())
  totalAmount   Float         @map("total_amount")
  paymentMethod PaymentMethod @map("payment_method")
  userId        String?       @map("user_id")
  user          User?         @relation(fields: [userId], references: [id])
  soldBy        String?       @map("sold_by") // For quick display or legacy
  debtorName    String?       @map("debtor_name")
  debtorPhone   String?       @map("debtor_phone")
  authorizer    String?       @map("authorizer")
  customerId    String?       @map("customer_id")
  customer      Customer?     @relation(fields: [customerId], references: [id])
  items         SaleItem[]
  payments      Json?         // Stores multi-payment details: [{ method, amount }]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt

  @@map("sales")
}

model SaleItem {
  id        String         @id @default(cuid())
  saleId    String         @map("sale_id")
  sale      Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variantId String         @map("variant_id")
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int            @default(1)
  price     Float // price at time of sale
  createdAt DateTime       @default(now())

  @@map("sale_items")
}
