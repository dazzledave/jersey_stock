{
  "name": "jersey-stock-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "server": "npm run dev --workspace=@jersey-stock/server",
    "desktop": "npm run electron:dev --workspace=desktop",
    "dev": "concurrently \"npm run server\" \"npm run desktop\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
